# Mock mode: "true" (default) usa mocks internos do app.
# "false" usa o servidor Mockoon (pnpm mock) ou API real da FUMP.
EXPO_PUBLIC_USE_MOCK=true

# Base URL usada apenas quando EXPO_PUBLIC_USE_MOCK=false.
# Mockoon local (pnpm mock): http://10.0.2.2:3002 (emulador Android)
# Celular na mesma rede: use o IP da máquina (ex.: http://192.168.1.50:3002)
# API real da FUMP: endereço fornecido pela FUMP
EXPO_PUBLIC_API_URL=http://10.0.2.2:3002
